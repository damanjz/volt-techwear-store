{
  "name": "techwear-store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:dev": "node scripts/db-toggle.mjs dev && npx prisma generate",
    "db:prod": "node scripts/db-toggle.mjs prod && npx prisma generate",
    "build": "node scripts/db-toggle.mjs prod && npx prisma db push --accept-data-loss && npx prisma generate && next build"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.577.0",
    "next": "15.5.12",
    "next-auth": "^4.24.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@prisma/client": "^6.1.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.12",
    "prisma": "^6.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5"
  }
}
