generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ────────────────────────────────────────

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  password       String?

  // Syndicate Identity
  voltPoints     Int       @default(0)
  clearanceLevel Int       @default(1)
  role           String    @default("USER")   // USER | ADMIN
  isBanned       Boolean   @default(false)

  accounts       Account[]
  sessions       Session[]
  orders         Order[]
}

model Product {
  id           String   @id @default(cuid())
  name         String
  description  String
  price        Int      // Changed from Float to Int cents
  category     String
  imageUrl     String
  isNew        Boolean  @default(false)
  stock        Int      @default(100)
  isActive     Boolean  @default(true)
  isClassified Boolean  @default(false)
  tags         String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orderItems   OrderItem[]
  coupons      CouponProduct[]
}

model Order {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  total        Int      // Cents
  discount     Int      @default(0) // Cents
  couponCode   String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  items        OrderItem[]

  @@index([userId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  quantity  Int
  price     Int     // Cents

  @@index([orderId])
  @@index([productId])
}

// ─── Coupon Engine ──────────────────────────────────────────

model Coupon {
  id               String    @id @default(cuid())
  code             String    @unique
  description      String    @default("")
  discountType     String    // PERCENT | FLAT
  value            Int       // Cents if FLAT, integer percentage if PERCENT
  scope            String    @default("SITE") // SITE | PRODUCT | CATEGORY
  category         String?
  usageLimit       Int       @default(0) // 0 = unlimited
  usedCount        Int       @default(0)
  isActive         Boolean   @default(true)
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())

  applicableProducts CouponProduct[]
}

model CouponProduct {
  id        String  @id @default(cuid())
  couponId  String
  coupon    Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([couponId, productId])
  @@index([couponId])
  @@index([productId])
}

// ─── Admin System ───────────────────────────────────────────

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  target    String   @default("")
  details   String   @default("")
  createdAt DateTime @default(now())
}
